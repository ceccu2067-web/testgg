local Players = game:GetService("Players")
local player = Players.LocalPlayer  -- For local scripts
-- Or use Players:GetPlayers() for server scripts

-- Get the player's character and position
local character = player.Character
if character then
    local rootPart = character:FindFirstChild("HumanoidRootPart")
    if rootPart then
        local position = rootPart.Position  -- Vector3 value
        print(player.Name .. " is at:", position)
    end
end
